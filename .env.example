# LLM Configuration
# Required (put your real keys in .env, not in git)
GROQ_API_KEY=your-groq-key
OPENAI_API_KEY=your-openai-key

# Application Settings
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ChromaDB Configuration
# For local dev (no Docker), keep CHROMA_HOST as localhost/127.0.0.1 to use the embedded persistent client.
# For Docker Compose, the container overrides CHROMA_HOST=chromadb automatically.
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=novatech_knowledge_base

# Agent Configuration
CONFIDENCE_THRESHOLD=0.75
MAX_KB_RESULTS=5
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=llama-3.3-70b-versatile

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/tickets.db

# LLM Configuration
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# Application Settings
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ChromaDB Configuration
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=novatech_knowledge_base

# Agent Configuration
CONFIDENCE_THRESHOLD=0.75
MAX_KB_RESULTS=5
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=llama-3.3-70b-versatile

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/tickets.db
